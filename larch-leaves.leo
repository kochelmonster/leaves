  }
  else if (0) {
    // muss übereinstimmen
    current().find(*this); // not back.node (pop_back!)
    
    stack_t cmp(stack);

    resize(1);
    
    current().find(*this); // not back.node (pop_back!)
    
    stack_t::reverse_iterator j, k;
