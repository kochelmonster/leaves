#ifdef _32BIT
size_t popcount(boost::uint64_t v) {
    boost::uint32_t *v32 = (boost::uint32_t*)&amp;v;
    return popcount32(v32[0]) + popcount32(v32[1])
  }
  
inline int ffs(boost::uint64_t v) {
    boost::uint32_t *v32 = (boost::uint32_t*)&amp;v;
    if (v32[0])
      return ffs32(v32[0]);
     
    return ffs32(v32[1]) + 32;
  }

inline int ffs(boost::uint64_t v) {
    boost::uint32_t *v32 = (boost::uint32_t*)&amp;v;
    if (v32[1])
      return clz32(v32[1]) + 32;
      
    return clz32(v32[0])
  }
 
#endif
