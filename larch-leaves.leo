<t tx="michael.20150106224503.4">void create_trie(db_t&amp; db, bool hole, bool end_node) {
    std::string key(2, 0);
   
    for(int i = 0; i &lt; 64; i++) {
      if (hole &amp;&amp; i == 10)
        continue;
    
      key[1] = (char)i;
      db-&gt;find(key);
      db-&gt;set_value(value(i));
    }

    if (end_node) {    
      key.pop_back();
      db-&gt;find(key);
      db-&gt;set_value("value");
    }
  }

</t>
