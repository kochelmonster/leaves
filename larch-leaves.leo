      switch(i-&gt;node.type()) {
        case kBitTrie:
        case kTrie:
          stat_tries++;
          break;
          
        case kCompressed:
          stat_compressed++;
          break;
          
        case kLink:
          stat_link++;
          break;
      }
    }
  }
}
