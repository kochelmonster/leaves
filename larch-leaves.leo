<t tx="michael.20150110130802.12">void prev(NodeRef&amp; rnode, Node* data, Trace&amp; trace) {
    Slice key(trace.current_key());
    if (key.empty())
        trace.parent_prev();
    else
      trace.cut_key();
  }
