<t tx="michael.20150106224503.59">void keyappend(NodeRef&amp; rnode, Trace&amp; trace, nodeid_t* child_id) {
    trace.cut_key();
    Compressed *n = (Compressed*)rnode.node();
    trace.key.append(n-&gt;data, rnode.len());
    *child_id = n-&gt;child;
  }
