void segsev(int) {
  std::cerr &lt;&lt; "segmentation fault: "&lt;&lt; getpid() &lt;&lt; "\n";
  sleep(10000);
}

void myterminate () {
  std::cerr &lt;&lt; "terminate handler called: "&lt;&lt; getpid() &lt;&lt; "\n";
  abort();  // forces abnormal termination
}


struct SetTerminate {
  SetTerminate() {
    std::set_terminate(myterminate);
    signal(SIGSEGV, segsev);
  }
};

SetTerminate s;
