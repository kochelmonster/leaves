<t tx="michael.20150106224503.3">void test_IterTrie() {
    db_t db(new TestDatabase);
    std::string key(2, 0);    
    create_trie(db, true, false);
    
    db-&gt;first();
    int i = 0;
    while(db-&gt;is_valid()) {
      key[1] = i;

      out &lt;&lt; "check " &lt;&lt; i &lt;&lt; ":" 
          &lt;&lt; (db-&gt;key() == key) &lt;&lt; std::endl;
      BOOST_REQUIRE(db-&gt;key() == key);

      db-&gt;next();
      i++;
      if (i == 10)
        i++;
    }
    BOOST_REQUIRE(i == 64);
    
    i = 63;
    db-&gt;last();
    while(db-&gt;is_valid()) {
      key[1] = i;

      out &lt;&lt; "check " &lt;&lt; i &lt;&lt; ":" 
          &lt;&lt; (db-&gt;key() == key) &lt;&lt; std::endl;
      BOOST_REQUIRE(db-&gt;key() == key);

      db-&gt;prev();
      i--;
      if (i == 10)
        i--;
    }
    BOOST_REQUIRE(i == -1);
    
    // and do some finding
    key.assign(1, (char)0);
    db-&gt;find(key);
    BOOST_REQUIRE(!db-&gt;is_valid());    
    
    key.append(1, (char)0);
    db-&gt;find(key);
    BOOST_REQUIRE(db-&gt;is_valid());    
    
    key[1] = 10;
    db-&gt;find(key);
    BOOST_REQUIRE(!db-&gt;is_valid());
    
    key[1] = 11;
    db-&gt;find(key);
    BOOST_REQUIRE(db-&gt;is_valid());
  }
</t>
