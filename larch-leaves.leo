<t tx="michael.20141230111914.121">void parent_next() {
    if (size() &gt; 1) {
      pop();
      current().next(*this);
    }
  }
</t>
<t tx="michael.20141230111914.122">void parent_prev() {
    if (size() &gt; 1) {
