{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(gdb) Launch",
            "type": "cppdbg",
            "request": "launch",
            "_program": "${workspaceFolder}/build/db_bench_leaves",
            "_program": "${workspaceFolder}/build/test_memory",
            "program": "${workspaceFolder}/build/test_cursor",
            "args": [
                "-t",
                "insert_bigkeys"
            ],
            "_args": [
                "-t",
                "test_strings"
            ],
            "_args": [
                "-t",
                "test_big_area_revolve"
            ],
            "_args": [
                "--benchmarks=fillrand100K"
            ],
            "_args": [
                "--benchmarks=fillseq"
            ],
            "_args": [
                "--benchmarks=fillrandsync,fillrandom"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "(gdb) test_memory",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/test_memory",
            "args": [
                "-t",
                "test_areamanager"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "(gdb) test_fstore",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/test_fstore",
            "_args": [
                "-t",
                "test_areamanager"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}