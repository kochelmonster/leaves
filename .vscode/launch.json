        {
            "name": "(gdb) Attach",
            "type": "cppdbg",
            "request": "attach",
            "program": "${workspaceFolder}/examples/kv_browser/build/kv_demo_server",
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "(gdb) Launch benchmark",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/db_bench_leaves",
            "args": [
                "--use_wal=1",
                "--benchmarks=fillrandom",
                "--batch_size=1",
                "--num=10000",
                "--batch_size=100000"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build",
            "environment": [
                {
                    "name": "DEBUGINFOD_URLS",
                    "value": ""
                }
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
