{
  "version": 4,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Leaves Default",
      "description": "Default local build with native tests and benchmarks enabled.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "LEAVES_BUILD_TESTS": "ON",
        "LEAVES_BUILD_BENCHMARKS": "ON"
      }
    },
    {
      "name": "ci-tests",
      "displayName": "Leaves CI Tests",
      "description": "CI-oriented test build with benchmarks disabled.",
      "inherits": "default",
      "binaryDir": "${sourceDir}/build/ci-tests",
      "cacheVariables": {
        "LEAVES_BUILD_BENCHMARKS": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default"
    },
    {
      "name": "ci-tests",
      "configurePreset": "ci-tests"
    }
  ],
  "testPresets": [
    {
      "name": "_default-base",
      "hidden": true,
      "configurePreset": "default",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error"
      }
    },
    {
      "name": "test-all",
      "inherits": "_default-base",
      "filter": {
        "label": {
          "include": "native"
        }
      }
    },
    {
      "name": "test-unit",
      "inherits": "_default-base",
      "filter": {
        "label": {
          "include": "unit"
        }
      }
    },
    {
      "name": "test-integration",
      "inherits": "_default-base",
      "filter": {
        "label": {
          "include": "integration"
        }
      }
    },
    {
      "name": "test-stress",
      "inherits": "_default-base",
      "filter": {
        "label": {
          "include": "stress"
        }
      }
    },
    {
      "name": "_ci-base",
      "hidden": true,
      "configurePreset": "ci-tests",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error"
      }
    },
    {
      "name": "ci-all",
      "inherits": "_ci-base",
      "filter": {
        "label": {
          "include": "native"
        }
      }
    },
    {
      "name": "ci-unit",
      "inherits": "_ci-base",
      "filter": {
        "label": {
          "include": "unit"
        }
      }
    },
    {
      "name": "ci-integration",
      "inherits": "_ci-base",
      "filter": {
        "label": {
          "include": "integration"
        }
      }
    },
    {
      "name": "ci-stress",
      "inherits": "_ci-base",
      "filter": {
        "label": {
          "include": "stress"
        }
      }
    }
  ]
}