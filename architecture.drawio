  <diagram name="Tributary Lifecycle" id="trib-lifecycle-2025">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" background="none" math="0" shadow="0">
      <root>
        <mxCell id="tl-0" />
        <mxCell id="tl-1" parent="tl-0" />

        <!-- Title -->
        <mxCell id="tl-title" value="ConfluenceDB: Tributary Slot Lifecycle" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1;" vertex="1" parent="tl-1">
          <mxGeometry x="327" y="20" width="700" height="50" as="geometry" />
        </mxCell>

        <!-- ── States ── -->
        <mxCell id="tl-free" value="FREE" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=18;fontStyle=1;" vertex="1" parent="tl-1">
          <mxGeometry x="527" y="110" width="200" height="80" as="geometry" />
        </mxCell>

        <mxCell id="tl-writing" value="WRITING" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=18;fontStyle=1;" vertex="1" parent="tl-1">
          <mxGeometry x="160" y="340" width="200" height="80" as="geometry" />
        </mxCell>

        <mxCell id="tl-merging" value="MERGING" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=18;fontStyle=1;" vertex="1" parent="tl-1">
          <mxGeometry x="900" y="340" width="200" height="80" as="geometry" />
        </mxCell>

        <mxCell id="tl-merged" value="MERGED" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=18;fontStyle=1;" vertex="1" parent="tl-1">
          <mxGeometry x="527" y="560" width="200" height="80" as="geometry" />
        </mxCell>

        <!-- ── Transitions ── -->

        <!-- FREE → WRITING : claim_tributary() -->
        <mxCell id="tl-e1" value="claim_tributary()&#xa;CAS FREE→WRITING, refs++" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;align=center;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="tl-free" target="tl-writing" parent="tl-1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="527" y="150" />
              <mxPoint x="260" y="150" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- WRITING → FREE : release, below threshold -->
        <mxCell id="tl-e2" value="release_tributary()&#xa;write_count &lt; threshold" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;align=center;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="tl-writing" target="tl-free" parent="tl-1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="260" y="240" />
              <mxPoint x="627" y="240" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- WRITING → MERGING : release, at/above threshold -->
        <mxCell id="tl-e3" value="release_tributary()&#xa;write_count ≥ threshold" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;align=center;" edge="1" source="tl-writing" target="tl-merging" parent="tl-1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="260" y="460" />
              <mxPoint x="1000" y="460" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- FREE → MERGING : idle timeout -->
        <mxCell id="tl-e4" value="merge_eligible_tributaries()&#xa;idle timeout / monitor" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;align=center;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="tl-free" target="tl-merging" parent="tl-1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="727" y="150" />
              <mxPoint x="1000" y="150" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- MERGING → MERGED : _do_merge() done -->
        <mxCell id="tl-e5" value="_do_merge() complete&#xa;state = MERGED" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;align=center;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="tl-merging" target="tl-merged" parent="tl-1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1000" y="580" />
              <mxPoint x="727" y="580" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- MERGED → FREE : _recycle_slot() when refs==0 -->
        <mxCell id="tl-e6" value="_recycle_slot()&#xa;reset_in_place() + state=FREE&#xa;triggered when refs drops to 0" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;align=center;" edge="1" source="tl-merged" target="tl-free" parent="tl-1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ── Crash Recovery Panel ── -->
        <mxCell id="tl-cr-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;opacity=60;" vertex="1" parent="tl-1">
          <mxGeometry x="120" y="690" width="1020" height="180" as="geometry" />
        </mxCell>
        <mxCell id="tl-cr-head" value="Crash Recovery: sanitize() → _merge_unclaimed_tributaries()" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontStyle=1;fontSize=14;" vertex="1" parent="tl-1">
          <mxGeometry x="140" y="700" width="760" height="26" as="geometry" />
        </mxCell>
        <mxCell id="tl-cr-body" value="For every tributary slot (pool is idle, safe lock-free scan):&#xa;  1.  t.sanitize()              — resets txn_ref_lock + txn_lock  (clears stuck spinlock left by crashed writer)&#xa;  2.  slot.refs = 0&#xa;  3a. state == MERGED           → _recycle_slot()     (finish interrupted recycle)&#xa;  3b. state == anything else    → state = FREE → merge_tributary()  (drain pending writes)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;" vertex="1" parent="tl-1">
          <mxGeometry x="140" y="728" width="980" height="130" as="geometry" />
        </mxCell>

        <!-- ── ref-count note ── -->
        <mxCell id="tl-refs-note" value="refs pin count: writers + readers (cursors via txn_ref()) + merger&#xa;A slot in MERGED state is recycled only when refs reaches 0  (last pinner calls _unpin_slot → _recycle_slot)." style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=11;" vertex="1" parent="tl-1">
          <mxGeometry x="120" y="890" width="1020" height="50" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
